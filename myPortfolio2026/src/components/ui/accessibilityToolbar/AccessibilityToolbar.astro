---
interface Props {
  themeLabel: string;
  listenLabel: string;
  spacingLabel: string;
  fontIncreaseLabel: string;
  fontDecreaseLabel: string;
  fontResetLabel: string;
}

const { themeLabel, listenLabel, spacingLabel, fontIncreaseLabel, fontDecreaseLabel, fontResetLabel } = Astro.props;
---

<!-- Accessibility Toolbar -->
<div class="fixed right-0 top-1/3 z-[100] flex items-center accessibility-toolbar" id="a11y-toolbar">
  <!-- Toggle Button -->
  <div
    id="a11y-toggle"
    aria-label="Accessibility toolbar"
    class="bg-primary text-on-primary px-3 py-6 rounded-l-xl shadow-2xl flex flex-col items-center gap-4 border border-white/10 border-r-0 cursor-pointer transform translate-x-full transition-transform duration-300"
  >
    <span class="material-symbols-outlined text-2xl">settings_accessibility</span>
  </div>

  <!-- Toolbar Panel -->
  <div 
    id="a11y-panel"
    class="bg-surface-container-high border border-outline-variant/30 border-r-0 shadow-2xl p-4 rounded-l-xl flex flex-col gap-4 transform translate-x-full transition-transform duration-300"
  >
    <!-- Theme Toggle (Dark/Light Mode) -->
    <button 
      aria-label="Toggle dark and light mode" 
      class="w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary/10 text-on-surface transition-colors group" 
      id="theme-toggle"
      title={themeLabel}
    >
      <span class="material-symbols-outlined group-active:scale-110 transition-transform" id="theme-icon">light_mode</span>
    </button>

    <!-- Text-to-Speech Toggle -->
    <button 
      aria-label="Listen to page content" 
      class="w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary/10 text-on-surface transition-colors group" 
      id="listen-toggle"
      title={listenLabel}
    >
      <span class="material-symbols-outlined" id="listen-icon">volume_up</span>
    </button>

    <!-- Text Spacing Toggle -->
    <button 
      aria-label="Toggle enhanced text spacing" 
      class="w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary/10 text-on-surface transition-colors group" 
      id="spacing-toggle"
      title={spacingLabel}
    >
      <span class="material-symbols-outlined group-active:scale-110 transition-transform">format_line_spacing</span>
    </button>

    <div class="h-px bg-outline-variant/30 w-full"></div>

    <!-- Font Size Controls -->
    <button 
      aria-label="Increase text size" 
      class="w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary/10 text-on-surface transition-colors group"
      id="font-increase"
      title={fontIncreaseLabel}
    >
      <span class="material-symbols-outlined group-active:scale-125 transition-transform">text_increase</span>
    </button>

    <button 
      aria-label="Decrease text size" 
      class="w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary/10 text-on-surface transition-colors group"
      id="font-decrease"
      title={fontDecreaseLabel}
    >
      <span class="material-symbols-outlined group-active:scale-125 transition-transform">text_decrease</span>
    </button>

    <button 
      aria-label="Reset text size" 
      class="w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary/10 text-on-surface transition-colors group"
      id="font-reset"
      title={fontResetLabel}
    >
      <span class="material-symbols-outlined group-active:rotate-180 transition-transform">refresh</span>
    </button>
  </div>
</div>

<script>
  import { 
    increaseFontSize, 
    decreaseFontSize, 
    resetFontSize,
    toggleTheme,
    toggleTextSpacing,
    initAccessibility,
    TextToSpeech 
  } from '@/helpers/accessibility';

  // Initialize accessibility on page load
  initAccessibility();

  // Initialize Text-to-Speech
  const tts = new TextToSpeech();

  // Panel toggle logic
  const toggleBtn = document.getElementById('a11y-toggle');
  const panel = document.getElementById('a11y-panel');
  const toolbar = document.getElementById('a11y-toolbar');
  let isPanelOpen = false;

  // Toggle panel on button click
  toggleBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    isPanelOpen = !isPanelOpen;
    
    if (isPanelOpen) {
      toggleBtn?.classList.remove('translate-x-full');
      panel?.classList.remove('translate-x-full');
      toggleBtn?.classList.add('translate-x-0');
      panel?.classList.add('translate-x-0');
    } else {
      panel?.classList.remove('translate-x-0');
      toggleBtn?.classList.remove('translate-x-0');
      panel?.classList.add('translate-x-full');
      toggleBtn?.classList.add('translate-x-full');
    }
  });

  // Close panel when clicking outside
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    
    // Check if click is outside toolbar
    if (toolbar && !toolbar.contains(target) && isPanelOpen) {
      isPanelOpen = false;
      panel?.classList.remove('translate-x-0');
      panel?.classList.add('translate-x-full');
      toggleBtn?.classList.remove('translate-x-0');
      toggleBtn?.classList.add('translate-x-full');
    }
  });

  // Prevent panel clicks from closing it
  panel?.addEventListener('click', (e) => {
    e.stopPropagation();
  });

  // Font size controls
  document.getElementById('font-increase')?.addEventListener('click', () => {
    const newSize = increaseFontSize();
    console.log('Font size increased to:', newSize);
  });

  document.getElementById('font-decrease')?.addEventListener('click', () => {
    const newSize = decreaseFontSize();
    console.log('Font size decreased to:', newSize);
  });

  document.getElementById('font-reset')?.addEventListener('click', () => {
    resetFontSize();
    console.log('Font size reset to 100%');
  });

  // Theme toggle (Dark/Light Mode)
  const themeBtn = document.getElementById('theme-toggle');
  const themeIcon = document.getElementById('theme-icon');
  
  themeBtn?.addEventListener('click', () => {
    const newTheme = toggleTheme();
    
    // Show opposite icon: if light mode is active, show dark_mode icon (to switch to dark)
    if (newTheme === 'light') {
      themeIcon!.textContent = 'dark_mode';
      themeBtn.classList.add('bg-primary/20', 'text-primary');
    } else {
      themeIcon!.textContent = 'light_mode';
      themeBtn.classList.remove('bg-primary/20', 'text-primary');
    }
  });

  // Text spacing toggle
  const spacingBtn = document.getElementById('spacing-toggle');
  spacingBtn?.addEventListener('click', () => {
    const isActive = toggleTextSpacing();
    
    if (isActive) {
      spacingBtn.classList.add('bg-primary/20', 'text-primary');
    } else {
      spacingBtn.classList.remove('bg-primary/20', 'text-primary');
    }
  });

  // Text-to-Speech toggle
  const listenBtn = document.getElementById('listen-toggle');
  const listenIcon = document.getElementById('listen-icon');
  
  listenBtn?.addEventListener('click', () => {
    const isReading = tts.toggle();
    
    if (isReading) {
      listenIcon!.textContent = 'stop_circle';
      listenBtn.classList.add('bg-primary/20', 'text-primary');
    } else {
      listenIcon!.textContent = 'volume_up';
      listenBtn.classList.remove('bg-primary/20', 'text-primary');
    }
  });

  // Restore active states on page load
  import { getAccessibilitySettings } from '@/helpers/accessibility';
  
  const settings = getAccessibilitySettings();
  
  // Show opposite icon: if light mode is active, show dark_mode icon (to switch to dark)
  if (settings.theme === 'light') {
    themeIcon!.textContent = 'dark_mode';
    themeBtn?.classList.add('bg-primary/20', 'text-primary');
  } else {
    themeIcon!.textContent = 'light_mode';
  }
  
  if (settings.textSpacing) {
    spacingBtn?.classList.add('bg-primary/20', 'text-primary');
  }
</script>
