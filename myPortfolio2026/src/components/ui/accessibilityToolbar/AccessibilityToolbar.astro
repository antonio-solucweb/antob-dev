---
// Accessibility Toolbar Component
---

<!-- Accessibility Toolbar -->
<div class="fixed right-0 top-1/3 z-[100] flex items-center accessibility-toolbar" id="a11y-toolbar">
  <div class="bg-primary text-on-primary px-3 py-6 rounded-l-xl shadow-2xl flex flex-col items-center gap-4 border border-white/10 border-r-0">
    <span class="material-symbols-outlined text-2xl">settings_accessibility</span>
  </div>
  <div class="bg-surface-container-high border border-outline-variant/30 border-r-0 shadow-2xl p-4 rounded-l-xl flex flex-col gap-4">
    <button 
      aria-label="Toggle Dark and Light Mode" 
      class="w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary/10 text-on-surface transition-colors group" 
      id="theme-toggle"
    >
      <span class="material-symbols-outlined group-active:rotate-90 transition-transform">dark_mode</span>
    </button>
    <button 
      aria-label="Listen to page content" 
      class="w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary/10 text-on-surface transition-colors group" 
      id="listen-toggle"
    >
      <span class="material-symbols-outlined">text_to_speech</span>
    </button>
    <div class="h-px bg-outline-variant/30 w-full"></div>
    <button 
      aria-label="Increase text size" 
      class="w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary/10 text-on-surface transition-colors"
    >
      <span class="material-symbols-outlined">text_increase</span>
    </button>
    <button 
      aria-label="Decrease text size" 
      class="w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary/10 text-on-surface transition-colors"
    >
      <span class="material-symbols-outlined">text_decrease</span>
    </button>
  </div>
</div>
