---
import { ExperienceDataSchema } from '@/types/index';
import { getLanguageFromCookieValue } from '@/helpers/i18n';

// Static imports for build compatibility
import experienceDataEn from '@assets/data/en/experience.json';
import experienceDataEs from '@assets/data/es/experience.json';
import experienceDataPt from '@assets/data/pt/experience.json';

const lang = getLanguageFromCookieValue(Astro.cookies.get('portfolio-language')?.value);
const experienceData = lang === 'es' ? experienceDataEs : lang === 'pt' ? experienceDataPt : experienceDataEn;

// Validate experience data
const result = ExperienceDataSchema.safeParse(experienceData);
if (!result.success) {
  console.error('Experience data validation failed:', result.error);
}
const data = result.success ? result.data : { interface: { titleLine1: '', titleLine2: '', subtitle: '', yearsText: '', yearsNumber: 0, countriesText: '', countriesNumber: 0, linkedinText: '' }, timeline: [], linkedinUrl: '' };
---

<section class="py-24 bg-surface relative overflow-hidden" id="experience">
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-12 gap-12">
      <!-- Left Column - Header & Stats -->

      {data.interface && (
      <div class="lg:col-span-4 space-y-6">
        <h2 class="text-5xl font-extrabold font-headline tracking-tighter leading-none">
          {data.interface.titleLine1} <br /> <span class="text-primary">{data.interface.titleLine2}</span>
        </h2>
        <p class="text-on-surface-variant font-body">
          {data.interface.subtitle}
        </p>
        
        <!-- Stats -->
        <div class="flex gap-4">
          <div class="text-center">
            <div class="text-4xl font-bold text-primary font-headline">+ {data.interface.yearsNumber}</div>
            <div class="text-xs uppercase tracking-widest font-label text-outline">{data.interface.yearsText}</div>
          </div>
          <div class="w-px h-12 bg-outline-variant/30"></div>
          <div class="text-center">
            <div class="text-4xl font-bold text-primary font-headline">+ {data.interface.countriesNumber}</div>
            <div class="text-xs uppercase tracking-widest font-label text-outline">{data.interface.countriesText}</div>
          </div>
        </div>
      </div>
      )}

      <!-- Right Column - Timeline -->
      <div class="lg:col-span-8 relative">
        <!-- Vertical Line -->
        <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-primary/50 via-outline-variant/20 to-transparent transform -translate-x-1/2 hidden md:block"></div>

        {data.timeline.map((item, index) => {
          const isEven = index % 2 === 0;
          const dotColor = item.isActive 
            ? 'bg-primary border-4 border-surface shadow-[0_0_15px_rgba(173,198,255,0.6)]' 
            : index === 1 
              ? 'bg-outline border-4 border-surface' 
              : 'bg-outline-variant border-4 border-surface';
          
          return (
            <div class={`relative ${index < data.timeline.length - 1 ? 'mb-16' : ''} md:flex md:justify-between items-center w-full`}>
              {/* Left Side (for even items on desktop) */}
              {isEven ? (
                <div class="md:w-5/12 hidden md:block"></div>
              ) : (
                <div class="md:w-5/12 glass-panel p-8 rounded-xl mr-8 md:mr-0 text-left md:text-right">
                  <span class="text-xs font-label text-primary tracking-widest uppercase">{item.period}</span>
                  <h4 class="text-xl font-bold font-headline mt-1 mb-2">{item.company} - {item.position}</h4>
                  <h5 class="text-sm font-semibold font-headline my-1 mb-2">{item.location}</h5>
                  <p class="text-on-surface-variant text-sm leading-relaxed whitespace-pre-line">{item.description}</p>
                </div>
              )}

              {/* Center Dot */}
              <div class={`absolute left-0 md:left-1/2 w-4 h-4 rounded-full ${dotColor} z-10 transform -translate-x-1/2`}></div>

              {/* Right Side (for even items on desktop) */}
              {isEven ? (
                <div class="md:w-5/12 glass-panel p-8 rounded-xl ml-8 md:ml-0">
                  <span class="text-xs font-label text-primary tracking-widest uppercase">{item.period}</span>
                  <h4 class="text-xl font-bold font-headline mt-1 mb-2">{item.company} - {item.position}</h4>
                  <h5 class="text-sm font-semibold font-headline my-1 mb-2">{item.location}</h5>
                  <p class="text-on-surface-variant text-sm leading-relaxed whitespace-pre-line">{item.description}</p>
                </div>
              ) : (
                <div class="md:w-5/12 hidden md:block"></div>
              )}
            </div>
          );
        })}
      </div>
    </div>

    {/* LinkedIn Link */}
    {data.interface.linkedinText && data.linkedinUrl && (
      <div class="text-center mt-7">
        <p class="text-on-surface-variant text-lg leading-relaxed font-body">
          {data.interface.linkedinText}{' '}
          <a 
            href={data.linkedinUrl} 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-primary font-bold hover:underline"
          >
            LinkedIn
          </a>.
        </p>
      </div>
    )}
  </div>
</section>
