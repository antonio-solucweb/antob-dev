---
import { getContactInfo, getWhatsAppLink } from '@/helpers/contactInfo';
import { ContactDataSchema } from '@/types';
import { getLanguageFromCookieValue } from '@/helpers/i18n';

import contactDataEn from '@assets/data/en/contact.json';
import contactDataEs from '@assets/data/es/contact.json';
import contactDataPt from '@assets/data/pt/contact.json';

const lang = getLanguageFromCookieValue(Astro.cookies.get('portfolio-language')?.value);
const rawContactData = lang === 'es' ? contactDataEs : lang === 'pt' ? contactDataPt : contactDataEn;

const result = ContactDataSchema.safeParse(rawContactData);
if (!result.success) {
  console.error('Contact data validation failed:', result.error);
}
const ui = result.success ? result.data.interfaces : null;

const contactInfo = getContactInfo();
const whatsappLink = ui ? getWhatsAppLink(ui.whatsappMessage) : '';
---

<section class="py-24 bg-surface-container-lowest relative overflow-hidden" id="contact">
  <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-primary/5 to-transparent"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto glass-panel rounded-2xl overflow-hidden shadow-2xl">
      <div class="grid md:grid-cols-2">
        <!-- Left Column - Contact Info -->
        <div class="p-12 bg-primary-container/20 space-y-8">
          <h2 class="text-4xl font-bold font-headline tracking-tight">
            {ui?.titleLine1} <br /> {ui?.titleLine2}
          </h2>
          <p class="text-on-surface-variant font-body leading-relaxed">
            {ui?.subtitle}
          </p>
          
          <!-- Contact Details -->
          <div class="space-y-6">
            <!-- WhatsApp -->
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined">chat</span>
              </div>
              <span class="font-label text-sm tracking-wide">
                <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">
                  {contactInfo.number}
                </a>
              </span>
            </div>
            
            <!-- Email -->
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined">mail</span>
              </div>
              <span class="font-label text-sm tracking-wide">
                <a href={`mailto:${contactInfo.email}`} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">
                  {contactInfo.email}
                </a>
              </span>
            </div>
            
            <!-- Location -->
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined">location_on</span>
              </div>
              <span class="font-label text-sm tracking-wide">
                {ui?.location}
              </span>
            </div>
          </div>
        </div>

        <!-- Right Column - Contact Form -->
        <div class="p-12 space-y-6">
          <form
            method="POST"
            action="/api/contact"
            class="space-y-4"
            id="contact-form"
            data-submit-text={ui?.submitButton}
            data-sending-text={ui?.sendingText}
            data-success-text={ui?.successText}
            data-error-text={ui?.errorText}
          >
            <!-- Name Field -->
            <div>
              <label for="name" class="block text-xs font-label text-outline uppercase tracking-widest mb-2">
                {ui?.nameLabel}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                minlength="2"
                class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary transition-all outline-none"
                placeholder={ui?.namePlaceholder}
              />
            </div>

            <!-- Email Field -->
            <div>
              <label for="email" class="block text-xs font-label text-outline uppercase tracking-widest mb-2">
                {ui?.emailLabel}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary transition-all outline-none"
                placeholder={ui?.emailPlaceholder}
              />
            </div>

            <!-- Message Field -->
            <div>
              <label for="message" class="block text-xs font-label text-outline uppercase tracking-widest mb-2">
                {ui?.messageLabel}
              </label>
              <textarea
                id="message"
                name="message"
                required
                minlength="10"
                rows="4"
                class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary transition-all outline-none h-32 resize-none"
                placeholder={ui?.messagePlaceholder}
              ></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              class="w-full bg-primary text-on-primary font-bold py-4 rounded-lg hover:shadow-[0_0_20px_rgba(173,198,255,0.4)] transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
              id="submit-btn"
            >
              <span id="btn-text">{ui?.submitButton}</span>
              <span class="material-symbols-outlined text-sm" id="btn-icon">send</span>
            </button>

            <!-- Status Message -->
            <div id="form-status" class="hidden text-center text-sm font-label"></div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLSpanElement;
  const btnIcon = document.getElementById('btn-icon') as HTMLSpanElement;
  const formStatus = document.getElementById('form-status') as HTMLDivElement;

  const submitText = form?.dataset.submitText || 'Send Message';
  const sendingText = form?.dataset.sendingText || 'Sending...';
  const successText = form?.dataset.successText || '✓ Message sent successfully!';
  const errorText = form?.dataset.errorText || 'Failed to send message. Please try again.';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Disable button
    submitBtn.disabled = true;
    btnText.textContent = sendingText;
    btnIcon.textContent = 'hourglass_empty';
    formStatus.classList.add('hidden');

    try {
      const formData = new FormData(form);
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
      });

      const result = await response.json();

      if (response.ok) {
        // Success
        formStatus.textContent = successText;
        formStatus.classList.remove('hidden', 'text-error');
        formStatus.classList.add('text-primary');
        form.reset();
        
        // Reset button after delay
        setTimeout(() => {
          btnText.textContent = submitText;
          btnIcon.textContent = 'send';
          submitBtn.disabled = false;
          formStatus.textContent = '';
        }, 2000);
      } else {
        throw new Error(result.error?.message || errorText);
      }
    } catch (error) {
      // Error
      formStatus.textContent = `✗ ${error instanceof Error ? error.message : errorText}`;
      formStatus.classList.remove('hidden', 'text-primary');
      formStatus.classList.add('text-error');
      
      // Reset button
      setTimeout(() => {
        btnText.textContent = submitText;
        btnIcon.textContent = 'send';
        submitBtn.disabled = false;
        formStatus.textContent = '';
      }, 5000);
    }
  });
</script>
