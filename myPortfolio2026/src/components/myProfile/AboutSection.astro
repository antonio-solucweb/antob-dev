---
import { Picture } from "astro:assets";
import profileImage from "@assets/img/img-antonio_blanca.jpg";

// About Section Component - The Architect's Profile
---

<section class="py-24 bg-surface relative" id="about">
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      <!-- Left Content - Image -->
      <div class="relative group">
        <!-- Corner Decorations -->
        <div class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-primary/40"></div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 border-b-2 border-r-2 border-primary/40"></div>
        
        <!-- Profile Image -->
        <Picture 
          alt="Antonio Blanca" 
          class="rounded-lg shadow-2xl relative z-10 opacity-70 group-hover:opacity-100 transition-all duration-700" 
          src={profileImage}
          width={512}
          height={512}
          widths={[512, 1024]}
          sizes="(max-width: 1024px) 100vw, 50vw"
          formats={['avif', 'webp', 'jpg']}
          loading="eager" />
      </div>
      
      <!-- Right Content - Text -->
      <div class="space-y-8">
        <!-- Title -->
        <div class="space-y-4">
          <h2 class="text-4xl md:text-5xl font-bold font-headline tracking-tighter">
            The Engineer's <span class="text-primary">Profile</span>
          </h2>
          <p class="text-on-surface-variant text-lg leading-relaxed font-body">
            With <span class="text-primary font-bold">over 7 years of rigorous experience</span> as a web developer, I have built a career on the principles of logic and efficiency. My transition from standard development to complex system architecture allows me to deliver <span class="text-primary font-bold">WordPress ecosystems that are modular, scalable, and lightning-fast</span>.
          </p>
        </div>
        
        <!-- Core Info Grid -->
        <div class="grid grid-cols-2 gap-8">
          <div class="space-y-2">
            <h4 class="font-headline font-bold text-primary">Core Philosophy</h4>
            <p class="text-sm text-outline tracking-wide uppercase font-label">Modular &amp; Scalable</p>
          </div>
          <div class="space-y-2">
            <h4 class="font-headline font-bold text-primary">Technical Niche</h4>
            <p class="text-sm text-outline tracking-wide uppercase font-label">Modern WordPress Development</p>
          </div>
        </div>
        
        <!-- Quote -->
        <div class="pt-4 border-l-2 border-primary/20 pl-6 space-y-4">
          <p class="italic text-on-secondary-container">
            "Throughout my career, I have gone beyond the basics, mastering advanced features such as custom theme and plugin development, multisite environments, ACF, Headless WordPress solutions, WordPress and external APIs, and more. My mission is to transform ideas into effective and functional digital solutions."
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
