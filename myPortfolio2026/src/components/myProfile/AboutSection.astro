---
import { Picture } from "astro:assets";
import profileImage from "@assets/img/img-antonio_blanca.jpg";
import { ProfileDataSchema } from '@/types';
import { getLanguageFromCookieValue } from '@/helpers/i18n';

import profileDataEn from '@assets/data/en/profile.json';
import profileDataEs from '@assets/data/es/profile.json';
import profileDataPt from '@assets/data/pt/profile.json';

const lang = getLanguageFromCookieValue(Astro.cookies.get('portfolio-language')?.value);
const rawProfileData = lang === 'es' ? profileDataEs : lang === 'pt' ? profileDataPt : profileDataEn;

const result = ProfileDataSchema.safeParse(rawProfileData);
if (!result.success) {
  console.error('Profile data validation failed:', result.error);
}
const ui = result.success ? result.data.interfaces : null;
---

<section class="py-24 bg-surface relative" id="about">
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      <!-- Left Content - Image -->
      <div class="relative group">
        <!-- Corner Decorations -->
        <div class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-primary/40"></div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 border-b-2 border-r-2 border-primary/40"></div>
        
        <!-- Profile Image -->
        <Picture 
          alt={ui?.imageAlt ?? 'Antonio Blanca'} 
          class="rounded-lg shadow-2xl relative z-10 opacity-70 group-hover:opacity-100 transition-all duration-700" 
          src={profileImage}
          width={512}
          height={512}
          widths={[512, 1024]}
          sizes="(max-width: 1024px) 100vw, 50vw"
          formats={['avif', 'webp', 'jpg']}
          loading="lazy" />
      </div>
      
      <!-- Right Content - Text -->
      <div class="space-y-8">
        <!-- Title -->
        <div class="space-y-4">
          <h2 class="text-4xl md:text-5xl font-bold font-headline tracking-tighter">
            {ui?.titleRegular} <span class="text-primary">{ui?.titleHighlight}</span>
          </h2>
          <p class="text-on-surface-variant text-lg leading-relaxed font-body [&_strong]:text-primary [&_strong]:font-bold" set:html={ui?.description} />
        </div>
        
        <!-- Core Info Grid -->
        <div class="grid grid-cols-2 gap-8">
          <div class="space-y-2">
            <h4 class="font-headline font-bold text-primary">{ui?.corePhilosophyLabel}</h4>
            <p class="text-sm text-outline tracking-wide uppercase font-label">{ui?.corePhilosophyValue}</p>
          </div>
          <div class="space-y-2">
            <h4 class="font-headline font-bold text-primary">{ui?.technicalNicheLabel}</h4>
            <p class="text-sm text-outline tracking-wide uppercase font-label">{ui?.technicalNicheValue}</p>
          </div>
        </div>
        
        <!-- Quote -->
        <div class="pt-4 border-l-2 border-primary/20 pl-6 space-y-4">
          <p class="italic text-on-secondary-container">
            "{ui?.quote}"
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
