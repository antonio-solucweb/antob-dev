---
import AccessibilityToolbar from '@components/ui/accessibilityToolbar/AccessibilityToolbar.astro';
import MainNavbar from '@components/ui/mainNavbar/MainNavbar.astro';
import FloatWhatsapp from '@components/floatWhatsapp/FloatWhatsapp.astro';
import { getLanguageFromCookieValue } from '@/helpers/i18n';
import { getWhatsAppLink } from '@/helpers/contactInfo';
import { GlobalUiSchema, ContactDataSchema } from '@/types';
import '@styles/global.css';

import uiDataEn from '@assets/data/en/ui.json';
import uiDataEs from '@assets/data/es/ui.json';
import uiDataPt from '@assets/data/pt/ui.json';

import contactDataEn from '@assets/data/en/contact.json';
import contactDataEs from '@assets/data/es/contact.json';
import contactDataPt from '@assets/data/pt/contact.json';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const currentLang = getLanguageFromCookieValue(Astro.cookies.get('portfolio-language')?.value);

const rawUiData = currentLang === 'es' ? uiDataEs : currentLang === 'pt' ? uiDataPt : uiDataEn;
const uiResult = GlobalUiSchema.safeParse(rawUiData);
const ui = uiResult.success ? uiResult.data.interfaces : null;
const a11y = uiResult.success ? uiResult.data.accessibility : null;

const rawContactData = currentLang === 'es' ? contactDataEs : currentLang === 'pt' ? contactDataPt : contactDataEn;
const contactResult = ContactDataSchema.safeParse(rawContactData);
const whatsappMessage = contactResult.success ? contactResult.data.interfaces.whatsappMessage : '';
const tooltipText = contactResult.success ? contactResult.data.interfaces.tooltipText : 'Talk with me on WhatsApp!';
const whatsappLink = getWhatsAppLink(whatsappMessage);
---

<!doctype html>
<html lang={currentLang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{ui?.pageTitle ?? title}</title>
    <meta name="description" content={ui?.metaDescription} />
    <meta property="og:title" content={ui?.pageTitle ?? title} />
    <meta property="og:description" content={ui?.metaDescription} />
    <meta property="og:type" content="website" />
    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=Inter:wght@400&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript>
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=Inter:wght@400&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet">
    </noscript>
    <!-- Material Symbols Icons (subsetted to used icons only) -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=arrow_forward,avg_time,chat,close,cloud_upload,code,code_blocks,css,dark_mode,database,design_services,expand_more,flowchart,format_line_spacing,home,host,javascript,layers,light_mode,location_on,mail,merge,network_node,php,play_circle,plug_connect,refresh,rocket,settings_accessibility,shield,shopping_cart,show_chart,stop_circle,text_decrease,text_increase,tile_small,timeline,volume_up,work,hourglass_empty,send&display=swap" media="print" onload="this.media='all'" />
    <!-- Critical CSS - Inline for faster FCP -->
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      }
      img, picture {
        max-width: 100%;
        height: auto;
      }
    </style>
  </head>
  
  <body class="bg-surface text-on-surface font-body selection:bg-primary selection:text-on-primary">
    <!-- Accessibility Toolbar -->
    <AccessibilityToolbar
      themeLabel={a11y?.theme ?? 'Toggle Theme'}
      listenLabel={a11y?.listen ?? 'Read Aloud'}
      spacingLabel={a11y?.spacing ?? 'Text Spacing'}
      fontIncreaseLabel={a11y?.fontIncrease ?? 'Increase Font Size'}
      fontDecreaseLabel={a11y?.fontDecrease ?? 'Decrease Font Size'}
      fontResetLabel={a11y?.fontReset ?? 'Reset Font Size'}
    />

    <!-- Top Navigation -->
    <MainNavbar />

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-slate-950 w-full py-12 px-8 border-t border-slate-900">
      <div class="flex flex-col md:flex-row justify-between items-center max-w-screen-2xl mx-auto gap-6">
        <div class="text-blue-200 font-mono text-lg font-bold">ANTONIO BLANCA</div>
        
        <div class="text-slate-500 font-label text-xs uppercase tracking-widest text-center md:text-left">
          © {new Date().getFullYear()} {ui?.footerCopyright}
        </div>
        
        <div class="flex gap-6">
          <!-- <a 
            class="text-slate-500 hover:text-blue-300 transition-opacity opacity-80 hover:opacity-100 font-label text-xs uppercase tracking-widest" 
            href="https://github.com/antonio-solucweb" 
            target="_blank"
            rel="noopener noreferrer"
          >
            Github
          </a> -->
          <a 
            class="text-slate-500 hover:text-blue-300 transition-opacity opacity-80 hover:opacity-100" 
            href="https://www.linkedin.com/in/antonio-blanca/" 
            target="_blank"
            rel="noopener noreferrer"
            aria-label={ui?.footerLinkedInAriaLabel ?? 'LinkedIn'}
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>

    <!-- Scripts -->
    <script>
      // Theme toggle logic
      const themeToggle = document.getElementById('theme-toggle');
      themeToggle?.addEventListener('click', function() {
        document.documentElement.classList.toggle('dark');
      });

      // Active navigation state with Intersection Observer
      const sections = document.querySelectorAll('section[id]');
      const desktopLinks = document.querySelectorAll('.nav-link');
      const mobileLinks = document.querySelectorAll('.mobile-nav-link');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const targetHref = `#${entry.target.id}`;

            desktopLinks.forEach(link => {
              link.classList.remove('text-blue-300', 'border-b-2', 'border-blue-400', 'pb-1');
              link.classList.add('text-slate-400');
              if (link.getAttribute('href') === targetHref) {
                link.classList.remove('text-slate-400');
                link.classList.add('text-blue-300', 'border-b-2', 'border-blue-400', 'pb-1');
              }
            });

            mobileLinks.forEach(link => {
              link.classList.remove('bg-primary/10', 'text-primary');
              link.classList.add('text-on-surface');
              if (link.getAttribute('href') === targetHref) {
                link.classList.remove('text-on-surface');
                link.classList.add('bg-primary/10', 'text-primary');
              }
            });
          }
        });
      }, { threshold: 0.5 });

      sections.forEach(section => observer.observe(section));
    </script>

    <!-- Floating WhatsApp Button -->
    <FloatWhatsapp whatsappLink={whatsappLink} tooltipText={tooltipText} />
  </body>
</html>
